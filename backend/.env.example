# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3003
NODE_ENV=development

# WireFluid Blockchain
WIREFLUID_RPC=https://evm.wirefluid.com
WIREFLUID_CHAIN_ID=92533
WIREFLUID_NETWORK_NAME=WireFluid Testnet
WIREFLUID_CURRENCY=WIRE

# Contract (from deployment)
CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS_HERE

# Platform Wallet (your wallet address)
PLATFORM_WALLET=YOUR_WALLET_ADDRESS_HERE

# PRIVATE KEY (NEVER commit - keep secret)
# Add this line to your actual .env file:
# PRIVATE_KEY=0xYourPrivateKeyHere

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=psl_fanchain

WALLET_MNEMONIC_TRUFFLE=water reason vague another toe resist wrist eight celery split away erupt
