# Frontend Environment Variables
# Copy to .env and configure

# Backend API (use deployed backend URL)
REACT_APP_API_URL=https://psl-fanchain.onrender.com

# QR Code API (optional)
REACT_APP_QR_API_URL=https://api.qrserver.com/v1/create-qr-code/

# WireFluid Blockchain
REACT_APP_WIREFLUID_RPC=https://evm.wirefluid.com
REACT_APP_CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS_HERE
REACT_APP_CHAIN_ID=92533
REACT_APP_NETWORK_NAME=WireFluid Testnet
